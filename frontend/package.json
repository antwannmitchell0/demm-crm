{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/verify-production-config.js",
    "build": "next build",
    "postbuild": "node scripts/verify-no-localhost-in-bundle.js",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
