# Database Configuration (PostgreSQL connection string)
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/demm_crm?schema=public"

# JSON Web Token Secret (Must be at least 32 characters long)
JWT_SECRET="<MINIMUM_32_CHAR_SECRET_KEY>"

# Port Configuration
PORT=3001

# CORS Allowed Origins (comma separated)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
