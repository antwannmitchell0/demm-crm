// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ORG_OWNER
  ORG_ADMIN
  WORKSPACE_ADMIN
  AGENT
  USER
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum ContactStatus {
  LEAD
  CONTACTED
  PROPOSAL
  CUSTOMER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  SYSTEM_EVENT
}

enum OfferLifecycleState {
  DRAFT
  ACTIVE
  RETIRED
}

enum MarketingServiceStatus {
  PENDING_ONBOARDING
  ACTIVE
  AT_RISK
  PAUSED
  CHURNED
}

enum OnboardingPlanState {
  NOT_STARTED
  IN_PROGRESS
  WAITING_ON_CLIENT
  BLOCKED
  READY_FOR_LAUNCH
  COMPLETE
  CANCELLED
}

enum ChecklistItemStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING_ON_CLIENT
  BLOCKED
  SUBMITTED
  COMPLETE
  WAIVED
  CANCELLED
}

enum ChecklistResponsibility {
  DEMM
  CLIENT
}

enum ServiceDeliverableCadence {
  ONE_TIME
  RECURRING
}

enum ServiceDeliverableStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  WAITING_ON_CLIENT
  DELIVERED
  ACCEPTED
  REJECTED
  CANCELLED
}

model Organization {
  id            String         @id @default(uuid())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspaces    Workspace[]
  memberships   Membership[]
  invitations   Invitation[]
  businessUnits BusinessUnit[]
  engrams       Engram[]
}

model Workspace {
  id             String            @id @default(uuid())
  name           String
  subdomain      String            @unique
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitId String?
  businessUnit   BusinessUnit?     @relation(fields: [businessUnitId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  contacts       Contact[]
  companies      Company[]
  pipelines      Pipeline[]
  opportunities  Opportunity[]
  auditLogs      AuditLog[]
  aiMemories     AIMemory[]
  memberships    Membership[]
  tasks          Task[]
  invitations    Invitation[]
  bookings       Booking[]
  equipment      Equipment[]
  wtaeEvents     WtaeEvent[]
  candidates     MemoryCandidate[]
  engrams        Engram[]
}

model BusinessUnit {
  id                 String                @id @default(uuid())
  name               String // "DEMM Marketing", "DEMM Photo Booths", etc.
  key                String // "MARKETING", "PHOTO_BOOTHS", "WTAE"
  organizationId     String
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaces         Workspace[]
  profiles           RelationshipProfile[]
  policies           MemoryAccessPolicy[]
  originatingConsent ConsentDirective[]    @relation("OriginatingConsent")
  destinationConsent ConsentDirective[]    @relation("DestinationConsent")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  engrams            Engram[]
  offers             Offer[]
  clientAccounts     ClientAccount[]

  @@unique([organizationId, key])
}

enum BookingStatus {
  INQUIRY
  QUOTE_SENT
  CONTRACT_SENT
  DEPOSIT_PAID
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Booking {
  id               String             @id @default(uuid())
  clientName       String
  clientEmail      String
  startTime        DateTime
  endTime          DateTime
  location         String
  packageSelected  String
  totalPrice       Decimal            @db.Decimal(12, 2)
  depositPaid      Decimal            @default(0.00) @db.Decimal(12, 2)
  status           BookingStatus      @default(INQUIRY)
  workspaceId      String
  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  equipment        BookingEquipment[]
  operatorId       String?
  operator         User?              @relation(fields: [operatorId], references: [id])
  wtaeEventId      String?            @unique
  wtaeEvent        WtaeEvent?         @relation(fields: [wtaeEventId], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  engramGraphEdges EngramGraphEdge[]
}

model Equipment {
  id             String             @id @default(uuid())
  name           String // "Booth Alpha", "Booth Beta", etc.
  type           String // "IPAD", "DSLR"
  serialNumber   String             @unique
  status         String // "ACTIVE", "MAINTENANCE", "INACTIVE"
  lastInspection DateTime?
  nextInspection DateTime?
  workspaceId    String
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bookings       BookingEquipment[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model BookingEquipment {
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([bookingId, equipmentId])
}

model WtaeEvent {
  id               String                 @id @default(uuid())
  name             String
  eventDate        DateTime
  organizerName    String
  organizerEmail   String
  slug             String                 @unique
  workspaceId      String
  workspace        Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  photos           PhotoAsset[]
  consentRecords   ConsentRecord[]
  attendees        AttendeeRegistration[]
  booking          Booking?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  flowers          Flower[]
  engramGraphEdges EngramGraphEdge[]
}

model PhotoAsset {
  id          String        @id @default(uuid())
  url         String
  wtaeEventId String
  wtaeEvent   WtaeEvent     @relation(fields: [wtaeEventId], references: [id], onDelete: Cascade)
  claims      MomentClaim[]
  createdAt   DateTime      @default(now())
}

model AttendeeRegistration {
  id              String          @id @default(uuid())
  email           String?
  phone           String?
  sessionCode     String          @unique
  wtaeEventId     String
  wtaeEvent       WtaeEvent       @relation(fields: [wtaeEventId], references: [id], onDelete: Cascade)
  consentRecords  ConsentRecord[]
  momentClaims    MomentClaim[]
  flowersGiven    Flower[]        @relation("FlowersGiver")
  flowersReceived Flower[]        @relation("FlowersRecipient")
  createdAt       DateTime        @default(now())
}

model ConsentRecord {
  id                     String               @id @default(uuid())
  attendeeRegistrationId String
  attendee               AttendeeRegistration @relation(fields: [attendeeRegistrationId], references: [id], onDelete: Cascade)
  wtaeEventId            String
  wtaeEvent              WtaeEvent            @relation(fields: [wtaeEventId], references: [id], onDelete: Cascade)
  noticeVersion          String // E.g. "v1.0"
  photoParticipation     Boolean              @default(false)
  communicationsAllowed  Boolean              @default(false)
  crossBusinessAllowed   Boolean              @default(false)
  withdrawalState        Boolean              @default(false)
  withdrawalTimestamp    DateTime?
  createdAt              DateTime             @default(now())
}

model MomentClaim {
  id                     String               @id @default(uuid())
  photoAssetId           String
  photoAsset             PhotoAsset           @relation(fields: [photoAssetId], references: [id], onDelete: Cascade)
  attendeeRegistrationId String
  attendee               AttendeeRegistration @relation(fields: [attendeeRegistrationId], references: [id], onDelete: Cascade)
  flowers                Flower[]
  createdAt              DateTime             @default(now())
}

model Flower {
  id              String               @id @default(uuid())
  giverId         String
  giver           AttendeeRegistration @relation("FlowersGiver", fields: [giverId], references: [id])
  recipientId     String
  recipient       AttendeeRegistration @relation("FlowersRecipient", fields: [recipientId], references: [id])
  wtaeEventId     String
  wtaeEvent       WtaeEvent            @relation(fields: [wtaeEventId], references: [id])
  momentClaimId   String?
  momentClaim     MomentClaim?         @relation(fields: [momentClaimId], references: [id])
  category        String // "TRUST", "EXCELLENCE", "SERVICE"
  moderationState String // "PENDING", "APPROVED", "FLAGGED"
  createdAt       DateTime             @default(now())
}

// // --- DOM26-R Known & Remembered Engine (Revision 6) ---

enum MemoryForm {
  SEMANTIC
  EPISODIC
  PROCEDURAL
  WORKING
  GOVERNANCE
}

enum MemoryTopic {
  IDENTITY
  RELATIONSHIP
  PREFERENCE
  JOURNEY
  MILESTONE
  COMMITMENT
  SERVICE_CONTEXT
  ISSUE_AND_RESOLUTION
}

enum TruthClassification {
  CONFIRMED
  OBSERVED
  INFERRED
  EXPIRED
  DISPUTED
}

enum SensitivityClassification {
  PUBLIC
  INTERNAL
  RESTRICTED
  CONFIDENTIAL
}

enum EngramState {
  ACTIVE
  EXPIRED
  DISPUTED
  DELETED
}

enum PulseState {
  NEW
  ACTIVE
  GROWING
  AT_RISK
  INACTIVE
  RETURNING
  ADVOCATE
}

enum SubjectType {
  CONTACT
  COMPANY
}

enum CandidateState {
  PENDING
  APPROVED
  REJECTED
}

enum SourceType {
  AGENT
  MANUAL
  EVENT
}

enum SeverityState {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SignalState {
  ACTIVE
  RESOLVED
}

enum ConsentStatus {
  GRANTED
  WITHDRAWN
  EXPIRED
}

enum ConsentChannel {
  WEB
  MOBILE
  EMAIL
  IN_PERSON
}

model RelationshipSubject {
  id        String                @id @default(uuid())
  type      SubjectType
  contactId String?               @unique
  contact   Contact?              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId String?               @unique
  company   Company?              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profiles  RelationshipProfile[]
  consent   ConsentDirective[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model RelationshipProfile {
  id             String               @id @default(uuid())
  subjectId      String
  subject        RelationshipSubject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  businessUnitId String
  businessUnit   BusinessUnit         @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  pulse          PulseState           @default(NEW)
  engrams        Engram[]
  signals        RelationshipSignal[]
  briefs         RelationshipBrief[]
  candidates     MemoryCandidate[]
  pulseHistory   PulseChangeHistory[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([subjectId, businessUnitId])
  @@index([businessUnitId])
}

model PulseChangeHistory {
  id        String              @id @default(uuid())
  profileId String
  profile   RelationshipProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  oldPulse  PulseState
  newPulse  PulseState
  reason    String
  actorId   String?
  createdAt DateTime            @default(now())
}

model Engram {
  id                  String                    @id @default(uuid())
  profileId           String
  profile             RelationshipProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  organizationId      String
  organization        Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitId      String
  businessUnit        BusinessUnit              @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  workspaceId         String?
  workspace           Workspace?                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  form                MemoryForm
  topic               MemoryTopic
  truthClassification TruthClassification
  sensitivity         SensitivityClassification @default(INTERNAL)
  state               EngramState               @default(ACTIVE)
  summary             String
  structuredContent   Json?
  evidence            EngramEvidence[]
  corrections         MemoryCorrection[]
  graphEdges          EngramGraphEdge[]         @relation("SourceEngram")
  targetEdges         EngramGraphEdge[]         @relation("TargetEngram")
  briefs              BriefEvidence[]
  signals             SignalEvidence[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  lastConfirmedAt     DateTime?
  expiresAt           DateTime?

  // engram.service.ts findAll(): every list query filters by businessUnitId
  // (+ optional profileId) and excludes state=DELETED -- this is the
  // primary DOM26-R read path.
  @@index([businessUnitId, state])
  @@index([profileId, state])
  // "active Engrams by ... class[ification] and expiration" -- not yet a
  // coded query, but truthClassification and expiresAt are explicit
  // doctrine filter dimensions on this model (TruthClassification enum,
  // EXPIRED state) and this is cheap to have ready before real volume.
  @@index([businessUnitId, truthClassification])
  @@index([businessUnitId, expiresAt])
}

model EngramSource {
  id                String              @id @default(uuid())
  type              SourceType
  referenceId       String?
  actorId           String?
  evidence          EngramEvidence[]
  candidateEvidence CandidateEvidence[]
  createdAt         DateTime            @default(now())
}

model EngramEvidence {
  id        String       @id @default(uuid())
  engramId  String
  engram    Engram       @relation(fields: [engramId], references: [id], onDelete: Cascade)
  sourceId  String
  source    EngramSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  createdAt DateTime     @default(now())

  @@unique([engramId, sourceId])
  // "source-reference and provenance lookup" -- the unique index above
  // leads with engramId, so "which engrams cite source X" (the reverse
  // provenance direction) has no index without this.
  @@index([sourceId])
}

model EngramGraphEdge {
  id               String     @id @default(uuid())
  sourceEngramId   String
  sourceEngram     Engram     @relation("SourceEngram", fields: [sourceEngramId], references: [id], onDelete: Cascade)
  targetEngramId   String?
  targetEngram     Engram?    @relation("TargetEngram", fields: [targetEngramId], references: [id], onDelete: Cascade)
  bookingId        String?
  booking          Booking?   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  wtaeEventId      String?
  wtaeEvent        WtaeEvent? @relation(fields: [wtaeEventId], references: [id], onDelete: Cascade)
  relationshipType String // "REPLACES", "CONFLICTS_WITH", "BOOKING_LINK"
  createdAt        DateTime   @default(now())
}

model MemoryCandidate {
  id             String                    @id @default(uuid())
  profileId      String
  profile        RelationshipProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  organizationId String
  workspaceId    String?
  workspace      Workspace?                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  form           MemoryForm
  topic          MemoryTopic
  proposedTruth  TruthClassification
  confidence     Decimal                   @db.Decimal(5, 2)
  sensitivity    SensitivityClassification
  consentBasis   String
  summary        String
  content        Json?
  expiresAt      DateTime?
  status         CandidateState            @default(PENDING)
  approvals      MemoryApproval[]
  evidence       CandidateEvidence[]
  createdAt      DateTime                  @default(now())

  // memory-candidate.service.ts findAll()/findByIdScoped(): filters via the
  // profile relation (no direct businessUnitId column here) plus an
  // optional status filter -- "pending Memory Candidates" is the named
  // query this directly serves.
  @@index([profileId, status])
}

model CandidateEvidence {
  id          String          @id @default(uuid())
  candidateId String
  candidate   MemoryCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  sourceId    String
  source      EngramSource    @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  createdAt   DateTime        @default(now())

  @@unique([candidateId, sourceId])
  // Same reverse-provenance justification as EngramEvidence.sourceId above.
  @@index([sourceId])
}

model MemoryApproval {
  id           String          @id @default(uuid())
  candidateId  String
  candidate    MemoryCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status       CandidateState
  resolvedById String?
  resolvedBy   User?           @relation(fields: [resolvedById], references: [id])
  createdAt    DateTime        @default(now())
}

model MemoryCorrection {
  id               String   @id @default(uuid())
  engramId         String
  engram           Engram   @relation(fields: [engramId], references: [id], onDelete: Cascade)
  previousSummary  String
  previousContent  Json?
  correctedSummary String
  correctedContent Json?
  actorId          String?
  reason           String
  createdAt        DateTime @default(now())
}

model MemoryAccessPolicy {
  id                   String                      @id @default(uuid())
  businessUnitId       String
  businessUnit         BusinessUnit                @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  role                 Role
  allowedForms         MemoryForm[]
  allowedTopics        MemoryTopic[]
  allowedSensitivities SensitivityClassification[]
  createdAt            DateTime                    @default(now())
}

model MemoryAuditEvent {
  id             String   @id @default(uuid())
  organizationId String
  businessUnitId String
  workspaceId    String?
  profileId      String?
  engramId       String?
  candidateId    String?
  actorType      String // "USER", "AGENT"
  actorId        String?
  action         String
  purpose        String
  outcome        String
  correlationId  String
  metadata       Json?
  createdAt      DateTime @default(now())

  // "audit events by target and creation time" -- append-only log, queried
  // by whichever target id an investigation starts from (engram/candidate/
  // profile), and by correlationId to trace one request's full audit
  // trail. Also directly supports business-unit-scoped time-range
  // investigation (the kind this session ran manually against staging
  // Cloud Run logs -- this is what makes the same query fast against this
  // table once DOM26-R data exists).
  @@index([engramId, createdAt])
  @@index([candidateId, createdAt])
  @@index([profileId, createdAt])
  @@index([businessUnitId, createdAt])
  @@index([correlationId])
}

model ConsentDirective {
  id                     String              @id @default(uuid())
  subjectId              String
  subject                RelationshipSubject @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  originatingBusinessId  String
  originatingBusiness    BusinessUnit        @relation("OriginatingConsent", fields: [originatingBusinessId], references: [id])
  destinationBusinessId  String?
  destinationBusiness    BusinessUnit?       @relation("DestinationConsent", fields: [destinationBusinessId], references: [id])
  dataCategory           MemoryTopic
  purpose                String
  channel                ConsentChannel
  noticeVersion          String
  effectiveDate          DateTime
  expirationDate         DateTime?
  withdrawn              Boolean             @default(false)
  withdrawnAt            DateTime?
  supersedingDirectiveId String?
  status                 ConsentStatus       @default(GRANTED)
  createdAt              DateTime            @default(now())

  // consent-directive.service.ts isSharingAllowed(): subjectId +
  // originatingBusinessId + status, filtered further by expirationDate.
  // findAll() ORs across both originatingBusinessId and destinationBusinessId.
  // "Consent Directive status, destination, and expiration" is the named
  // requirement this set covers.
  @@index([subjectId, originatingBusinessId, status])
  @@index([destinationBusinessId])
  @@index([expirationDate])
}

model RelationshipSignal {
  id         String              @id @default(uuid())
  profileId  String
  profile    RelationshipProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type       String // "MILESTONE_ALERT", "BROKEN_COMMITMENT"
  summary    String
  confidence Decimal             @db.Decimal(5, 2)
  severity   SeverityState
  state      SignalState         @default(ACTIVE)
  ownerId    String?
  evidence   SignalEvidence[]
  expiresAt  DateTime?
  resolvedAt DateTime?
  createdAt  DateTime            @default(now())

  // "Relationship Signals by profile and state" -- no service reads this
  // model yet (deferred, out of Phase 1B scope per commit 60700d0), but
  // the query shape is named explicitly and the schema already exists.
  @@index([profileId, state])
}

model SignalEvidence {
  id       String             @id @default(uuid())
  signalId String
  signal   RelationshipSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  engramId String
  engram   Engram             @relation(fields: [engramId], references: [id], onDelete: Cascade)

  @@unique([signalId, engramId])
}

model RelationshipBrief {
  id          String                    @id @default(uuid())
  profileId   String
  profile     RelationshipProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  briefText   String
  generator   String
  version     String
  sensitivity SensitivityClassification
  evidence    BriefEvidence[]
  generatedAt DateTime                  @default(now())
  expiresAt   DateTime?
}

model BriefEvidence {
  id       String            @id @default(uuid())
  briefId  String
  brief    RelationshipBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  engramId String
  engram   Engram            @relation(fields: [engramId], references: [id], onDelete: Cascade)

  @@unique([briefId, engramId])
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workspace      Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role           Role         @default(USER)
  permissions    String[] // Explicit scopes e.g. ["contact:create"]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId, workspaceId])
}

model User {
  id                     String                        @id @default(uuid())
  email                  String                        @unique
  passwordHash           String
  firstName              String
  lastName               String
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  memberships            Membership[]
  contacts               Contact[] // Assigned owner
  opportunities          Opportunity[] // Assigned owner
  auditLogs              AuditLog[]
  approvals              AgentApproval[]               @relation("ResolverRelation")
  refreshTokens          RefreshToken[]
  bookings               Booking[]
  memoryApprovals        MemoryApproval[]
  commercialStateChanges ClientCommercialStateChange[]
  onboardingPlansOwned    OnboardingPlan[]          @relation("OnboardingPlanOwner")
  checklistItemsOwned     OnboardingChecklistItem[] @relation("ChecklistItemOwner")
  checklistItemsApproved  OnboardingChecklistItem[] @relation("ChecklistItemApprover")
  deliverablesOwned       ServiceDeliverable[]      @relation("ServiceDeliverableOwner")
}

model RefreshToken {
  id          String   @id @default(uuid())
  hashedToken String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Company {
  id                  String               @id @default(uuid())
  name                String
  domain              String?
  industry            String?
  workspaceId         String
  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts            Contact[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  relationshipSubject RelationshipSubject?
  clientAccounts      ClientAccount[]
}

model Contact {
  id             String               @id @default(uuid())
  firstName      String
  lastName       String
  emails         String[] // Supports multiple emails
  phones         String[] // Supports multiple phones
  address        Json? // Structured street, city, state, zip, country
  tags           String[]
  status         ContactStatus        @default(LEAD)
  source         String?
  leadScore      Int                  @default(0)
  customFields   Json? // User-defined key-values
  aiSummary      String?
  aiRecommends   Json? // Structured recommendations & explanation
  workspaceId    String
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyId      String?
  company        Company?             @relation(fields: [companyId], references: [id])
  ownerId        String?
  owner          User?                @relation(fields: [ownerId], references: [id]) // Account manager/salesperson
  opportunities  Opportunity[]
  notes          Note[]
  activities     Activity[]
  tasks          Task[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  subject        RelationshipSubject?
  clientAccounts ClientAccount[]
}

model Pipeline {
  id            String        @id @default(uuid())
  name          String
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages        Stage[]
  opportunities Opportunity[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Stage {
  id            String        @id @default(uuid())
  name          String
  order         Int
  pipelineId    String
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Opportunity {
  id              String            @id @default(uuid())
  name            String
  value           Decimal           @default(0.00) @db.Decimal(12, 2)
  probability     Int               @default(0)
  expectedClose   DateTime?
  status          OpportunityStatus @default(OPEN)
  workspaceId     String
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipelineId      String
  pipeline        Pipeline          @relation(fields: [pipelineId], references: [id])
  stageId         String
  stage           Stage             @relation(fields: [stageId], references: [id])
  contactId       String?
  contact         Contact?          @relation(fields: [contactId], references: [id])
  ownerId         String?
  owner           User?             @relation(fields: [ownerId], references: [id])
  aiInsights      String?
  source          String? // acquisition source for THIS business relationship
  industryContext String? // temp qualification context when Company unknown
  clientAccount   ClientAccount?    @relation("AcquisitionOpportunity")
  notes           Note[]
  activities      Activity[]
  tasks           Task[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// --- Marketing Business Unit: Offer / ClientAccount (Phase 2 Lead-to-Client Core) ---

model Offer {
  id                     String              @id @default(uuid())
  businessUnitId         String
  businessUnit           BusinessUnit        @relation(fields: [businessUnitId], references: [id], onDelete: Restrict)
  key                    String
  version                Int                 @default(1)
  name                   String
  price                  Decimal             @db.Decimal(12, 2)
  setupFee               Decimal?            @db.Decimal(12, 2)
  includedServices       String[]
  excludedServices       String[]
  onboardingRequirements String[]
  // Nullable by design (2026-07-23 Commercial Truth Lock): unlike
  // includedServices/price, these four have no confirmed answer for most
  // tiers yet. A required NOT NULL column would force fabricating customer
  // promises (launch time, cancellation terms) that were never actually
  // decided -- null means "not yet defined," not "empty string."
  supportBoundaries      String?
  reportingCadence       String?
  cancellationTerms      String?
  expectedLaunchTime     String?
  lifecycleState         OfferLifecycleState @default(DRAFT)
  isPubliclyAvailable    Boolean             @default(false)
  snapshots              OfferSnapshot[]
  clientAccounts         ClientAccount[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@unique([businessUnitId, key, version])
  @@index([businessUnitId, lifecycleState])
}

model OfferSnapshot {
  id                     String         @id @default(uuid())
  offerId                String
  offer                  Offer          @relation(fields: [offerId], references: [id], onDelete: Restrict)
  offerVersion           Int
  key                    String
  name                   String
  price                  Decimal        @db.Decimal(12, 2)
  setupFee               Decimal?       @db.Decimal(12, 2)
  includedServices       String[]
  excludedServices       String[]
  onboardingRequirements String[]
  supportBoundaries      String?
  reportingCadence       String?
  cancellationTerms      String?
  expectedLaunchTime     String?
  clientAccount          ClientAccount?
  onboardingPlans        OnboardingPlan[]
  serviceDeliverables    ServiceDeliverable[]
  createdAt              DateTime       @default(now())
}

model ClientAccount {
  id                       String                        @id @default(uuid())
  businessUnitId           String
  businessUnit             BusinessUnit                  @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  companyId                String?
  company                  Company?                      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  primaryContactId         String
  primaryContact           Contact                       @relation(fields: [primaryContactId], references: [id], onDelete: Restrict)
  acquisitionOpportunityId String                        @unique
  acquisitionOpportunity   Opportunity                   @relation("AcquisitionOpportunity", fields: [acquisitionOpportunityId], references: [id], onDelete: Restrict)
  offerId                  String
  offer                    Offer                         @relation(fields: [offerId], references: [id], onDelete: Restrict)
  offerSnapshotId          String                        @unique
  offerSnapshot            OfferSnapshot                 @relation(fields: [offerSnapshotId], references: [id], onDelete: Restrict)
  serviceStatus            MarketingServiceStatus        @default(PENDING_ONBOARDING)
  onboardingState          OnboardingPlanState           @default(NOT_STARTED)
  renewalDate              DateTime?
  commercialChanges        ClientCommercialStateChange[]
  idempotencyKeys          ConversionIdempotencyKey[]
  onboardingPlan           OnboardingPlan?
  serviceDeliverables      ServiceDeliverable[]
  health                   ClientHealth?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt

  @@unique([businessUnitId, companyId])
  @@unique([businessUnitId, primaryContactId])
  @@index([businessUnitId, serviceStatus])
}

model ClientCommercialStateChange {
  id              String        @id @default(uuid())
  clientAccountId String
  clientAccount   ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  field           String // "CONTRACT" | "PAYMENT"
  newValue        String // e.g. "SIGNED_MANUAL", "DEPOSIT_PAID_MANUAL"
  // Nullable by design: only meaningful for field="PAYMENT" rows, and only
  // when a real dollar amount was actually recorded (2026-07-23, added for
  // the Marketing Dashboard's revenue KPIs -- without this there was no way
  // to derive a real MANUALLY_RECORDED revenue figure, only guess at the
  // full OfferSnapshot price, which would misrepresent partial/deposit
  // payments as full payments).
  amount          Decimal?      @db.Decimal(12, 2)
  recordedById    String
  recordedBy      User          @relation(fields: [recordedById], references: [id])
  source          String        @default("MANUAL")
  createdAt       DateTime      @default(now())

  @@index([clientAccountId, field, createdAt])
}

model ConversionIdempotencyKey {
  key             String        @id
  clientAccountId String
  clientAccount   ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

// --- Marketing Business Unit: Onboarding / Service Delivery (Phase 2 Sub-project 2) ---

model OnboardingPlan {
  id               String              @id @default(uuid())
  clientAccountId  String              @unique
  clientAccount    ClientAccount       @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  offerSnapshotId  String
  offerSnapshot    OfferSnapshot       @relation(fields: [offerSnapshotId], references: [id], onDelete: Restrict)
  planVersion      Int                 @default(1)
  ownerId          String?
  owner            User?               @relation("OnboardingPlanOwner", fields: [ownerId], references: [id])
  targetLaunchDate DateTime?
  actualLaunchDate DateTime?
  state            OnboardingPlanState @default(NOT_STARTED)
  items            OnboardingChecklistItem[]
  overrides        LaunchGateOverride[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model OnboardingChecklistItem {
  id                String                    @id @default(uuid())
  planId            String
  plan              OnboardingPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  sourceCapability  String?
  required          Boolean                   @default(true)
  responsibility    ChecklistResponsibility
  assignedOwnerId   String?
  assignedOwner     User?                     @relation("ChecklistItemOwner", fields: [assignedOwnerId], references: [id])
  dueDate           DateTime?
  dependsOnItemId   String?
  dependsOnItem     OnboardingChecklistItem?  @relation("ItemDependency", fields: [dependsOnItemId], references: [id])
  dependentItems    OnboardingChecklistItem[] @relation("ItemDependency")
  status            ChecklistItemStatus       @default(NOT_STARTED)
  evidence          String?
  clientSubmission  Json?
  blockerReason     String?
  completedAt       DateTime?
  approvedById      String?
  approvedBy        User?                     @relation("ChecklistItemApprover", fields: [approvedById], references: [id])
  approvedAt        DateTime?
  history           OnboardingChecklistItemHistory[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([planId, status])
}

model OnboardingChecklistItemHistory {
  id         String                  @id @default(uuid())
  itemId     String
  item       OnboardingChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  oldStatus  ChecklistItemStatus
  newStatus  ChecklistItemStatus
  reason     String?
  actorId    String?
  createdAt  DateTime                @default(now())

  @@index([itemId, createdAt])
}

model LaunchGateOverride {
  id             String         @id @default(uuid())
  planId         String
  plan           OnboardingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  reason         String
  actorId        String
  affectedGates  String[]
  createdAt      DateTime       @default(now())

  @@index([planId, createdAt])
}

model ServiceDeliverable {
  id                     String                      @id @default(uuid())
  clientAccountId        String
  clientAccount          ClientAccount               @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  offerSnapshotId        String
  offerSnapshot          OfferSnapshot               @relation(fields: [offerSnapshotId], references: [id], onDelete: Restrict)
  sourceCapability       String
  name                   String
  description            String?
  cadence                ServiceDeliverableCadence
  cadenceDetail          String?
  ownerId                String?
  owner                  User?                       @relation("ServiceDeliverableOwner", fields: [ownerId], references: [id])
  dueDate                DateTime?
  status                 ServiceDeliverableStatus    @default(NOT_STARTED)
  evidence               String?
  clientApprovalRequired Boolean                     @default(false)
  clientApprovedAt       DateTime?
  blockerReason          String?
  outsideScope           Boolean                     @default(false)
  history                ServiceDeliverableHistory[]
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  @@index([clientAccountId, status])
}

model ServiceDeliverableHistory {
  id            String                   @id @default(uuid())
  deliverableId String
  deliverable   ServiceDeliverable       @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  oldStatus     ServiceDeliverableStatus
  newStatus     ServiceDeliverableStatus
  reason        String?
  actorId       String?
  createdAt     DateTime                 @default(now())

  @@index([deliverableId, createdAt])
}

// --- Marketing Business Unit: Client Health (Phase 2 Sub-project 3) ---
//
// Deliberately a SEPARATE model from ClientAccount.serviceStatus. Service
// status is the client's commercial lifecycle stage (PENDING_ONBOARDING /
// ACTIVE / AT_RISK / PAUSED / CHURNED); ClientHealth is a diagnostic,
// explainable risk assessment layered on top -- computed from real
// evidence, never a mysterious score. See ClientHealthService for the rule
// engine that populates `factors`/`missingData`.

enum ClientHealthState {
  HEALTHY
  WATCH
  AT_RISK
  CRITICAL
  PAUSED
  CHURNED
  UNKNOWN
}

model ClientHealth {
  id                String                 @id @default(uuid())
  clientAccountId   String                 @unique
  clientAccount     ClientAccount          @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  // `state` is what callers read -- overrideState if set, else computedState.
  // Both are stored explicitly so a human override never overwrites (and
  // therefore never hides) what the rule engine actually computed.
  state             ClientHealthState      @default(UNKNOWN)
  computedState     ClientHealthState      @default(UNKNOWN)
  overrideState     ClientHealthState?
  // Structured JSON array of { code, description, riskOwner, evidence }
  // -- riskOwner is one of DEMM/CLIENT/COMMERCIAL/RELATIONSHIP/DELIVERY,
  // matching the "distinguish who/what is causing the risk" requirement.
  factors           Json
  missingData       String[]
  recommendedAction String?
  calculatedAt      DateTime               @default(now())
  overrides         ClientHealthOverride[]
  history           ClientHealthHistory[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model ClientHealthOverride {
  id        String            @id @default(uuid())
  healthId  String
  health    ClientHealth      @relation(fields: [healthId], references: [id], onDelete: Cascade)
  state     ClientHealthState
  reason    String
  actorId   String
  createdAt DateTime          @default(now())

  @@index([healthId, createdAt])
}

model ClientHealthHistory {
  id        String            @id @default(uuid())
  healthId  String
  health    ClientHealth      @relation(fields: [healthId], references: [id], onDelete: Cascade)
  oldState  ClientHealthState
  newState  ClientHealthState
  trigger   String // "RECALCULATION" | "OVERRIDE" | "OVERRIDE_CLEARED"
  createdAt DateTime          @default(now())

  @@index([healthId, createdAt])
}

model Task {
  id            String       @id @default(uuid())
  title         String
  description   String?
  status        TaskStatus   @default(PENDING)
  dueDate       DateTime?
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Note {
  id            String       @id @default(uuid())
  content       String
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
}

model Activity {
  id            String       @id @default(uuid())
  type          ActivityType @default(SYSTEM_EVENT)
  description   String
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
}

model AuditLog {
  id          String    @id @default(uuid())
  actorType   String // USER, AGENT, SYSTEM
  actorId     String? // User ID or Agent ID
  action      String // API method name (e.g., createContact)
  payload     Json // Full input payload
  response    Json? // Response payload (excluding sensitive info)
  ipAddress   String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

model AIMemory {
  id          String    @id @default(uuid())
  domain      String // E.g., "sales", "Atlanta workflow"
  key         String // memory-key
  value       Json
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AgentApproval {
  id            String         @id @default(uuid())
  toolName      String
  arguments     Json
  status        ApprovalStatus @default(PENDING)
  workspaceId   String
  requestedById String
  resolvedById  String?
  resolvedBy    User?          @relation("ResolverRelation", fields: [resolvedById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Invitation {
  id             String           @id @default(uuid())
  email          String
  role           Role             @default(USER)
  workspaceId    String
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
}
